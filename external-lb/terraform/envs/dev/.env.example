# Cloudflare credentials
export TF_VAR_cloudflare_api_token="your-cloudflare-api-token-here"
export TF_VAR_account_id="your-cloudflare-account-id-here"
export TF_VAR_zone_id="your-cloudflare-zone-id-here"

# Tunnel secret - generate ONCE with: openssl rand -base64 32
# IMPORTANT: Do NOT regenerate this after initial setup
# Cloudflare will reject the tunnel if the secret changes
export TF_VAR_tunnel_secret="your-32-byte-base64-secret-here"
